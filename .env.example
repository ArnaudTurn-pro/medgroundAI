# medground — local configuration. Copy to `.env` and fill in.
#   cp .env.example .env
# Real environment variables and the MCP `-e` block always take precedence over this file.
# `.env` is gitignored; this template is committed. Never put real secrets in this file.

# --- Data location ---------------------------------------------------------------
# Absolute path recommended so the MCP server finds the corpus regardless of its CWD.
MG_DATA_DIR=/absolute/path/to/medground/data

# --- Embeddings -------------------------------------------------------------------
# DEFAULT is OpenAI text-embedding-3-large (3072-d). Just set the key:
OPENAI_API_KEY=sk-...
#
# Alternatives — set provider + model + dim TOGETHER (then run `medground reembed`):
#   Local (no key, offline, free):
#     MG_EMBED_PROVIDER=fastembed  MG_EMBED_MODEL=BAAI/bge-small-en-v1.5  MG_EMBED_DIM=384
#   Voyage (biomedical-strong):
#     MG_EMBED_PROVIDER=voyage  MG_EMBED_MODEL=voyage-3-large  MG_EMBED_DIM=1024  + VOYAGE_API_KEY=...

# --- PubMed / NCBI (OPTIONAL) -----------------------------------------------------
# Email is a courtesy NCBI requests (NOT a secret). An API key raises the rate limit 3 -> 10 req/s.
MG_NCBI_EMAIL=you@example.com
# MG_NCBI_API_KEY=

# --- CIViC (OPTIONAL) -----------------------------------------------------
MG_CIVIC_API_KEY=

# --- Background research tracker (OPTIONAL; ADR-0014) -----------------------------
# Run the watch loop INSIDE the MCP server process, so it tracks new research alongside Opus
# without a second process fighting for the file lock. Off by default — it ingests + embeds,
# which costs money. Set to 1 to enable; tick is the scheduler poll interval in seconds.
# MG_WATCH_IN_SERVER=1
# MG_WATCH_TICK=300
